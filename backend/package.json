{
  "name": "case-eventos-backend",
  "version": "1.0.0",
  "description": "API para gerenciamento de eventos e participantes",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths --resolve-full-extension .js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "keywords": [
    "events",
    "participants",
    "express",
    "typescript"
  ],
  "author": "Cledson96",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
